<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="eagleemu" />
		<Option pch_mode="2" />
		<Option compiler="clang" />
		<Build>
			<Target title="Debug">
				<Option output="bin/Debug/eagleemu" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Debug/" />
				<Option type="1" />
				<Option compiler="clang" />
				<Compiler>
					<Add option="-O2" />
					<Add option="-ggdb" />
					<Add option="-fno-omit-frame-pointer" />
				</Compiler>
			</Target>
			<Target title="Release">
				<Option output="bin/Release/eagleemu" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Release/" />
				<Option type="1" />
				<Option compiler="clang" />
				<Compiler>
					<Add option="-O2" />
				</Compiler>
				<Linker>
					<Add option="-s" />
				</Linker>
			</Target>
		</Build>
		<Compiler>
			<Add option="-Wall" />
			<Add option="`sdl2-config --cflags`" />
		</Compiler>
		<Linker>
			<Add option="`sdl2-config --libs`" />
			<Add option="-lm" />
			<Add option="-lSDL2_ttf" />
			<Add option="-L/usr/local/lib" />
			<Add option="-lSAASound" />
			<Add option="-lSDL2_mixer" />
			<Add option="-lncurses" />
		</Linker>
		<Unit filename="8255.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="8255.h" />
